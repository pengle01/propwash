[configuration]

entry_symbol = "propwash_library_init"
compatibility_minimum = "4.5"
reloadable = true

[libraries]

linux.debug.x86_64 = "res://bin/libpropwash.linux.template_debug.x86_64.so"
linux.release.x86_64 = "res://bin/libpropwash.linux.template_release.x86_64.so"
windows.debug.x86_64 = "res://bin/propwash.windows.template_debug.x86_64.dll"
windows.release.x86_64 = "res://bin/propwash.windows.template_release.x86_64.dll"
